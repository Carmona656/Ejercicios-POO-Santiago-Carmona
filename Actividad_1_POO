#Ejercicio_4
class Familia:     
    def calcular(self):         
        self.juan = int(input("Digite la edad de Juan: "))         
        self.alberto = int((2 * self.juan) / 3)         
        self.ana = int((4 * self.juan) / 3)         
        self.mama = self.juan + self.alberto + self.ana      
        
    def mostrar(self):         
        print(f"La edad de Juan es: {self.juan}")         
        print(f"La edad de Alberto es: {self.alberto}")         
        print(f"La edad de Ana es: {self.ana}")         
        print(f"La edad de la mamá es: {self.mama}")  
        
f = Familia() 
f.calcular() 
f.mostrar() 


#Ejercicio_5
class Operacion:     
    def __init__(self):         
        self.suma = 0         
        self.x = 0         
        self.y = 0      
        
    def calcular(self):         
        self.x = int(input("Digite un valor cualquiera: "))         
        self.suma = self.suma + self.x         
        self.y = int(input("Digite un valor cualquiera: "))         
        self.x = self.x + self.y ** 2         
        self.suma = self.suma + self.x / self.y      
        
    def mostrar(self):         
        print(f"La suma es: {self.suma}")  
        
op = Operacion() 
op.calcular() 
op.mostrar() 
