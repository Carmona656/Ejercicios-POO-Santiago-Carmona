#Ejercicio_14

class Numero:
    def __init__(self, valor):
        self.valor = valor
    
    def cuadrado(self):
        return self.valor ** 2
    
    def cubo(self):
        return self.valor ** 3

numero = float(input("Digite un número: "))
obj = Numero(numero)

print("Número:", obj.valor)
print("Cuadrado:", obj.cuadrado())
print("Cubo:", obj.cubo())
