#Ejercicio_17

import math
class Circulo:
    
    def __init__(self, radio):
        self.radio = radio
    
    def area(self):
        return math.pi * (self.radio ** 2)
    
    def longitud(self):
        return 2 * math.pi * self.radio

radio = float(input("Digite el radio del círculo: "))
obj = Circulo(radio)

print("Radio:", obj.radio)
print("Área del círculo:", obj.area())
print("Longitud de la circunferencia:", obj.longitud())
