#Ejercicio_12

class Empleado:
    def __init__(self):
        self.horas = 0
        self.valorHora = 0
        self.bruto = 0
        self.retencion = 0
        self.neto = 0
    
    def calcular(self):
        self.horas = int(input("Digite las horas trabajadas: "))
        self.valorHora = int(input("Digite el valor por hora: "))
        self.bruto = self.horas * self.valorHora
        self.retencion = self.bruto * 0.125
        self.neto = self.bruto - self.retencion
    
    def mostrar(self):
        print(f"Salario bruto: {self.bruto}")
        print(f"Retención en la fuente: {self.retencion}")
        print(f"Salario neto: {self.neto}")

e = Empleado()
e.calcular()
e.mostrar()
